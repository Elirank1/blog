---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getReadingTime } from '../utils/reading-time';

const base = import.meta.env.BASE_URL;

// WebSite JSON-LD for homepage
const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Eliran Keren",
  "description": "Founder of Deeplica — building AI-native infrastructure for founders and operators.",
  "url": "https://elirank1.github.io/blog",
  "author": {
    "@type": "Person",
    "name": "Eliran Keren",
    "url": "https://elirank1.github.io/blog/about",
    "sameAs": [
      "https://www.linkedin.com/in/elirankeren",
      "https://github.com/Elirank1"
    ]
  }
};

const recentPosts = await Astro.glob('./blog/*.{md,mdx}');
const sortedPosts = recentPosts
  .sort((a, b) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime())
  .slice(0, 5);
---

<BaseLayout>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />

  <!-- Hero -->
  <section class="py-12 text-center">
    <img src={`${base}/images/eliran-profile.jpg`} alt="Eliran Keren" class="w-20 h-20 rounded-full object-cover mx-auto mb-6" />
    <h1 class="text-4xl font-bold mb-3" id="hero-title">Eliran Keren</h1>
    <p class="text-lg max-w-lg mx-auto leading-relaxed" id="hero-sub">
      Founder of <a href="https://deeplica.ai" target="_blank" class="font-semibold">Deeplica</a> — building the coordination layer that runs the operational side of your life.
    </p>
    <div class="flex justify-center gap-4 mt-5">
      <a href="https://www.linkedin.com/in/elirankeren" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-gray-600 transition-colors" aria-label="LinkedIn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      <a href="https://github.com/Elirank1" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-gray-600 transition-colors" aria-label="GitHub">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      </a>
      <a href="mailto:eliran@deeplica.ai" class="text-gray-400 hover:text-gray-600 transition-colors" aria-label="Email">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
      </a>
    </div>
  </section>

  <!-- Recent Posts -->
  <section class="py-8">
    <h2 class="text-2xl font-bold mb-6" id="recent-heading">Recent Posts</h2>
    <div class="flex flex-col gap-1">
      {sortedPosts.map(post => {
        const readTime = post.rawContent ? getReadingTime(typeof post.rawContent === 'function' ? post.rawContent() : post.rawContent) : '';
        return (
          <a href={post.url} class="group block py-4 hover:no-underline border-b border-gray-100 last:border-b-0 post-row">
            <div class="flex justify-between items-start gap-4">
              <div>
                <h3 class="font-semibold group-hover:text-[--color-accent] transition-colors post-title">
                  {post.frontmatter.title}
                </h3>
                <p class="text-sm mt-1 line-clamp-1 post-desc">{post.frontmatter.description}</p>
              </div>
              <div class="text-sm text-gray-400 whitespace-nowrap flex-shrink-0 mt-0.5 post-date">
                {new Date(post.frontmatter.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                {readTime && <span class="ml-2 text-gray-300">· {readTime}</span>}
              </div>
            </div>
          </a>
        );
      })}
    </div>
    <a href={`${base}/blog`} class="inline-block mt-6 text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors">
      View all posts →
    </a>
  </section>
</BaseLayout>

<style>
  /* Light mode */
  #hero-title { color: var(--color-heading); }
  #hero-sub { color: var(--color-body); }
  #recent-heading { color: var(--color-heading); }
  .post-title { color: var(--color-body); }
  .post-desc { color: #6b7280; }
  .post-date { color: #9ca3af; }
  .post-row { border-color: #f3f4f6; }

  /* Dark mode */
  [data-theme="dark"] #hero-title { color: var(--color-heading); }
  [data-theme="dark"] #hero-sub { color: #9ca3af; }
  [data-theme="dark"] #recent-heading { color: var(--color-heading); }
  [data-theme="dark"] .post-row { border-color: #1f1f2e; }
  [data-theme="dark"] .post-title { color: #e5e7eb; }
  [data-theme="dark"] .post-desc { color: #6b7280; }
  [data-theme="dark"] .post-date { color: #4b5563; }
</style>
