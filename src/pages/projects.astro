---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Projects | Eliran Keren" description="Projects and open-source work by Eliran Keren">
  <div class="projects-page">
    <h1>Projects</h1>
    <p class="intro">Things I'm building, experimenting with, and sharing publicly.</p>

    <section class="project" id="deeplica">
      <div class="project-header">
        <h2>🧠 Deeplica</h2>
        <div class="project-links">
          <a href="https://deeplica.ai" target="_blank" rel="noopener noreferrer">Website</a>
        </div>
      </div>
      <p>
        The executive proxy layer for founders and operators. Deeplica is AI-native infrastructure
        that handles the operational layer — decision tracking, team communication, focus protection —
        so you can spend your time on the work that actually matters.
      </p>
      <div class="tech-stack">
        <span class="tech-tag">AI</span>
        <span class="tech-tag">Automation</span>
        <span class="tech-tag">Founder Tools</span>
      </div>
    </section>

    <section class="project" id="claude-toolkit">
      <div class="project-header">
        <h2>🤖 Claude Automation Toolkit</h2>
        <div class="project-links">
          <a href="https://github.com/Elirank1" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
      <p>
        An automation suite that integrates Claude AI with daily workflows — WhatsApp notifications,
        HubSpot CRM sync, Google Meet integration, and more. Built as an open experiment in
        AI-driven business operations.
      </p>
      <div class="tech-stack">
        <span class="tech-tag">Node.js</span>
        <span class="tech-tag">TypeScript</span>
        <span class="tech-tag">Claude API</span>
        <span class="tech-tag">MCP</span>
      </div>
    </section>

    <section class="project" id="suno-music">
      <div class="project-header">
        <h2>🎵 Suno Music Generator</h2>
        <div class="project-links">
          <a href="https://github.com/Elirank1" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
      <p>
        An AI-powered music generation app. Create original songs from text descriptions,
        customize genres, moods, and instruments. A fun side project exploring generative AI
        beyond text.
      </p>
      <div class="tech-stack">
        <span class="tech-tag">React</span>
        <span class="tech-tag">TypeScript</span>
        <span class="tech-tag">AI Models</span>
        <span class="tech-tag">Web Audio API</span>
      </div>
    </section>

    <section class="project">
      <div class="project-header">
        <h2>📝 This Blog</h2>
        <div class="project-links">
          <a href="https://github.com/Elirank1/blog" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
      <p>
        A fast, minimal technical blog built with Astro and MDX. Dark mode, RSS feed,
        tag-based filtering, and a clean reading experience.
      </p>
      <div class="tech-stack">
        <span class="tech-tag">Astro</span>
        <span class="tech-tag">TypeScript</span>
        <span class="tech-tag">MDX</span>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .projects-page {
    max-width: 800px;
  }

  .projects-page h1 {
    margin-bottom: 1rem;
  }

  .intro {
    font-size: 1.2rem;
    opacity: 0.8;
    margin-bottom: 3rem;
  }

  .project {
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    margin-bottom: 2rem;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .project-header h2 {
    margin: 0;
  }

  .project-links {
    display: flex;
    gap: 1rem;
  }

  .project-links a {
    font-weight: 500;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tech-tag {
    background: var(--color-code-bg);
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.85rem;
    font-family: var(--font-mono);
  }

  @media (max-width: 640px) {
    .project {
      padding: 1.5rem;
    }

    .project-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
