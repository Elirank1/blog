---
import BaseLayout from './BaseLayout.astro';
import AuthorBio from '../components/AuthorBio.astro';
import ShareLinks from '../components/ShareLinks.astro';
import { getReadingTime } from '../utils/reading-time';

const { frontmatter, rawContent } = Astro.props;
const base = import.meta.env.BASE_URL;

// Calculate reading time
let readTime = '';
if (rawContent) {
  readTime = getReadingTime(typeof rawContent === 'function' ? rawContent() : rawContent);
}

// Build OG image URL from slug
const slug = Astro.url.pathname.split('/').filter(Boolean).pop();
const ogImageUrl = `${base}/og/${slug}.png`;

// Format date
const formattedDate = new Date(frontmatter.pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={`${frontmatter.title} | Eliran Keren`}
  description={frontmatter.description || ''}
  image={ogImageUrl}
  article={true}
>
  <article class="max-w-none">
    <!-- Hero image -->
    {frontmatter.heroImage && (
      <img
        src={frontmatter.heroImage}
        alt={frontmatter.title}
        class="w-full rounded-xl mb-8 shadow-sm"
        loading="eager"
      />
    )}

    <!-- Post header -->
    <header class="mb-10">
      <h1 class="text-4xl font-bold leading-tight tracking-tight mb-4 text-gray-900" id="post-title">
        {frontmatter.title}
      </h1>
      <div class="flex items-center gap-3 flex-wrap text-sm text-gray-500" id="post-meta">
        <time datetime={frontmatter.pubDate}>{formattedDate}</time>
        {readTime && (
          <>
            <span>·</span>
            <span>{readTime}</span>
          </>
        )}
        {frontmatter.tags && frontmatter.tags.length > 0 && (
          <>
            <span>·</span>
            <div class="flex gap-2 flex-wrap">
              {frontmatter.tags.map((tag: string) => (
                <a
                  href={`${base}/tags/${tag}`}
                  class="text-[--color-accent] hover:underline text-sm"
                >#{tag}</a>
              ))}
            </div>
          </>
        )}
      </div>
    </header>

    <!-- Post content with prose styling -->
    <div class="prose prose-lg max-w-none" id="post-content">
      <slot />
    </div>

    <!-- Share links -->
    <ShareLinks title={frontmatter.title} url={Astro.url.pathname} />

    <!-- Author bio -->
    <AuthorBio />

    <!-- Back link -->
    <div class="mt-10">
      <a href={`${base}/blog`} class="text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors">
        ← Back to all posts
      </a>
    </div>
  </article>
</BaseLayout>

<style>
  [data-theme="dark"] #post-title {
    color: #f9fafb;
  }
  [data-theme="dark"] #post-meta {
    color: #9ca3af;
  }
  [data-theme="dark"] #post-content {
    color: #d1d5db;
  }
  [data-theme="dark"] #post-content :global(h2),
  [data-theme="dark"] #post-content :global(h3),
  [data-theme="dark"] #post-content :global(h4) {
    color: #f9fafb;
  }
  [data-theme="dark"] #post-content :global(strong) {
    color: #f3f4f6;
  }
  [data-theme="dark"] #post-content :global(a) {
    color: var(--color-accent-dark);
  }
  [data-theme="dark"] #post-content :global(blockquote) {
    border-color: var(--color-accent-dark);
    color: #9ca3af;
  }
  [data-theme="dark"] #post-content :global(code) {
    color: #e5e7eb;
    background-color: #1f2937;
  }

  @media (max-width: 640px) {
    #post-title {
      font-size: 1.875rem;
    }
  }
</style>
