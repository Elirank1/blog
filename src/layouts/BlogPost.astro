---
import BaseLayout from './BaseLayout.astro';
import AuthorBio from '../components/AuthorBio.astro';
import ShareLinks from '../components/ShareLinks.astro';
import { getReadingTime } from '../utils/reading-time';

const { frontmatter, rawContent } = Astro.props;
const base = import.meta.env.BASE_URL;

// Calculate reading time
let readTime = '';
if (rawContent) {
  readTime = getReadingTime(typeof rawContent === 'function' ? rawContent() : rawContent);
}

// Use hero image as OG/share image (LinkedIn thumbnail), fallback to generated OG
const slug = Astro.url.pathname.split('/').filter(Boolean).pop();
const ogImageUrl = frontmatter.heroImage || `${base}/og/${slug}.png`;

// Build canonical URL and full image URL for JSON-LD
const siteUrl = 'https://elirank1.github.io';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const fullImageUrl = ogImageUrl.startsWith('http') ? ogImageUrl : new URL(ogImageUrl, siteUrl).href;

// JSON-LD structured data for BlogPosting
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": frontmatter.title,
  "description": frontmatter.description || '',
  "datePublished": frontmatter.pubDate,
  "dateModified": frontmatter.updatedDate || frontmatter.pubDate,
  "author": {
    "@type": "Person",
    "name": "Eliran Keren",
    "url": `${siteUrl}/blog/about`,
    "jobTitle": "Founder & CEO",
    "sameAs": [
      "https://www.linkedin.com/in/elirankeren",
      "https://github.com/Elirank1"
    ],
    "worksFor": {
      "@type": "Organization",
      "name": "Deeplica.AI"
    }
  },
  "publisher": {
    "@type": "Person",
    "name": "Eliran Keren"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalUrl
  },
  "image": fullImageUrl,
  "keywords": frontmatter.tags ? frontmatter.tags.join(', ') : ''
};

// Format date
const formattedDate = new Date(frontmatter.pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={`${frontmatter.title} | Eliran Keren`}
  description={frontmatter.description || ''}
  image={ogImageUrl}
  article={true}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article class="max-w-none">
    <!-- Hero image -->
    {frontmatter.heroImage && (
      <img
        src={frontmatter.heroImage}
        alt={frontmatter.title}
        class="w-full rounded-xl mb-8 shadow-sm"
        loading="eager"
      />
    )}

    <!-- Post header -->
    <header class="mb-10">
      <h1 class="text-4xl font-bold leading-tight tracking-tight mb-4" id="post-title">
        {frontmatter.title}
      </h1>
      <div class="flex items-center gap-3 flex-wrap text-sm" id="post-meta">
        <time datetime={frontmatter.pubDate}>{formattedDate}</time>
        {readTime && (
          <>
            <span>·</span>
            <span>{readTime}</span>
          </>
        )}
        {frontmatter.tags && frontmatter.tags.length > 0 && (
          <>
            <span>·</span>
            <div class="flex gap-2 flex-wrap">
              {frontmatter.tags.map((tag: string) => (
                <a
                  href={`${base}/tags/${tag}`}
                  class="tag-link"
                >#{tag}</a>
              ))}
            </div>
          </>
        )}
      </div>
    </header>

    <!-- Post content with prose styling -->
    <div class="prose prose-lg dark:prose-invert max-w-none" id="post-content">
      <slot />
    </div>

    <!-- Share links -->
    <ShareLinks title={frontmatter.title} url={Astro.url.pathname} />

    <!-- Author bio -->
    <AuthorBio />

    <!-- Back link -->
    <div class="mt-10">
      <a href={`${base}/blog`} class="back-link">
        ← Back to all posts
      </a>
    </div>
  </article>
</BaseLayout>

<style>
  /* Light mode defaults */
  #post-title { color: var(--color-heading); font-family: 'MuseoModerno', sans-serif; }
  #post-meta { color: #6b7280; }
  .tag-link {
    color: var(--color-accent);
    font-size: 0.875rem;
    text-decoration: none;
  }
  .tag-link:hover { text-decoration: underline; }
  .back-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: #6b7280;
    transition: color 0.2s ease;
    text-decoration: none;
  }
  .back-link:hover { color: #374151; text-decoration: none; }

  /* Dark mode */
  [data-theme="dark"] #post-title { color: var(--color-heading); }
  [data-theme="dark"] #post-meta { color: #6b7280; }
  [data-theme="dark"] .back-link { color: #6b7280; }
  [data-theme="dark"] .back-link:hover { color: #9ca3af; }

  [data-theme="dark"] #post-content { color: var(--color-body); }
  [data-theme="dark"] #post-content :global(h1),
  [data-theme="dark"] #post-content :global(h2),
  [data-theme="dark"] #post-content :global(h3),
  [data-theme="dark"] #post-content :global(h4) {
    color: var(--color-heading);
    font-family: 'MuseoModerno', sans-serif;
  }
  [data-theme="dark"] #post-content :global(strong) { color: #e5e7eb; }
  [data-theme="dark"] #post-content :global(a) { color: #B8A4E8; }
  [data-theme="dark"] #post-content :global(a:hover) { color: #D0C1F0; }
  [data-theme="dark"] #post-content :global(blockquote) {
    border-color: #B8A4E8;
    color: #9ca3af;
  }
  [data-theme="dark"] #post-content :global(code) {
    color: #d1d5db;
    background-color: #1a1a24;
  }
  [data-theme="dark"] #post-content :global(li::marker) { color: #6b7280; }
  [data-theme="dark"] #post-content :global(hr) { border-color: #1f1f2e; }

  @media (max-width: 640px) {
    #post-title { font-size: 1.875rem; }
  }
</style>
