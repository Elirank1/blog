---
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title={`${frontmatter.title} | Eliran Keren`}
  description={frontmatter.description || ''}
  image={frontmatter.image || ''}
>
  <article class="blog-post">
    <header class="post-header">
      <h1>{frontmatter.title}</h1>
      <div class="post-meta">
        <time>{new Date(frontmatter.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        {frontmatter.tags && (
          <div class="tags">
            {frontmatter.tags.map((tag: string) => (
              <a href={`${base}/tags/${tag}`} class="tag">#{tag}</a>
            ))}
          </div>
        )}
      </div>
    </header>

    <div class="post-content">
      <slot />
    </div>

    <footer class="post-footer">
      <a href={`${base}/blog`} class="back-link">← Back to all posts</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .blog-post {
    max-width: 720px;
  }

  .post-header {
    margin-bottom: 3rem;
  }

  .post-header h1 {
    font-size: 2.5rem;
    line-height: 1.2;
    margin: 0 0 1rem 0;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    opacity: 0.7;
    font-size: 0.95rem;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.85rem;
    opacity: 0.8;
  }

  .tag:hover {
    opacity: 1;
  }

  .post-content {
    line-height: 1.8;
    font-size: 1.1rem;
  }

  .post-content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .post-content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .post-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .post-content :global(pre) {
    padding: 1.5rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .post-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
    margin: 1.5rem 0;
    opacity: 0.9;
  }

  .post-content :global(img) {
    max-width: 100%;
    border-radius: 8px;
    margin: 1.5rem 0;
  }

  .post-content :global(ul), .post-content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    font-weight: 500;
  }

  @media (max-width: 640px) {
    .post-header h1 {
      font-size: 1.8rem;
    }

    .post-content {
      font-size: 1rem;
    }
  }
</style>
