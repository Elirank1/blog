---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: boolean;
}

const {
  title = 'Eliran Keren | Tech Blog',
  description = 'Founder of Deeplica — building AI-native infrastructure for founders and operators.',
  image = '',
  article = false,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const siteUrl = 'https://elirank1.github.io';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImage = image ? new URL(image, siteUrl).href : new URL(`${base}/og-default.png`, siteUrl).href;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="alternate" type="application/rss+xml" title="RSS Feed" href={`${base}/rss.xml`} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / LinkedIn -->
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Eliran Keren" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <div class="max-w-3xl mx-auto px-5 min-h-screen flex flex-col">
      <header class="py-6 border-b border-gray-200" id="site-header">
        <nav class="flex justify-between items-center">
          <a href={base} class="text-xl font-bold text-gray-900 hover:no-underline" id="logo">Eliran Keren</a>
          <div class="flex gap-5 items-center">
            <a href={`${base}/blog`} class="text-gray-600 hover:text-gray-900 text-sm font-medium transition-colors nav-link">Blog</a>
            <a href={`${base}/about`} class="text-gray-600 hover:text-gray-900 text-sm font-medium transition-colors nav-link">About</a>
            <a href={`${base}/projects`} class="text-gray-600 hover:text-gray-900 text-sm font-medium transition-colors nav-link">Projects</a>
            <button id="theme-toggle" aria-label="Toggle dark mode" class="p-1 rounded-md hover:bg-gray-100 transition-colors text-lg">
              <span class="sun">☀️</span>
              <span class="moon">🌙</span>
            </button>
          </div>
        </nav>
      </header>

      <main class="flex-1 py-10">
        <slot />
      </main>

      <footer class="py-6 border-t border-gray-200 flex justify-between items-center flex-wrap gap-4 text-sm text-gray-500" id="site-footer">
        <p>© 2026 Eliran Keren. Built with <a href="https://astro.build" class="hover:text-gray-700">Astro</a></p>
        <div class="flex gap-4">
          <a href="https://www.linkedin.com/in/elirankeren" target="_blank" rel="noopener noreferrer" class="hover:text-gray-700 transition-colors">LinkedIn</a>
          <a href="https://github.com/Elirank1" target="_blank" rel="noopener noreferrer" class="hover:text-gray-700 transition-colors">GitHub</a>
          <a href={`${base}/rss.xml`} class="hover:text-gray-700 transition-colors">RSS</a>
        </div>
      </footer>
    </div>

    <script>
      const themeToggle = document.getElementById('theme-toggle');
      const html = document.documentElement;

      const savedTheme = localStorage.getItem('theme');
      const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

      if (savedTheme) {
        html.setAttribute('data-theme', savedTheme);
      } else if (systemDark) {
        html.setAttribute('data-theme', 'dark');
      }

      themeToggle?.addEventListener('click', () => {
        const currentTheme = html.getAttribute('data-theme');
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', newTheme);
        localStorage.setItem('theme', newTheme);
      });
    </script>

    <style>
      [data-theme="dark"] #logo {
        color: #f3f4f6;
      }
      [data-theme="dark"] .nav-link {
        color: #9ca3af;
      }
      [data-theme="dark"] .nav-link:hover {
        color: #f3f4f6;
      }
      [data-theme="dark"] #theme-toggle:hover {
        background-color: #1f2937;
      }
      [data-theme="dark"] #site-header,
      [data-theme="dark"] #site-footer {
        border-color: #1f2937;
      }
      [data-theme="dark"] #site-footer {
        color: #6b7280;
      }
      [data-theme="dark"] #site-footer a:hover {
        color: #d1d5db;
      }

      [data-theme="dark"] .sun { display: none; }
      [data-theme="light"] .moon,
      html:not([data-theme]) .moon { display: none; }

      @media (max-width: 640px) {
        nav {
          flex-direction: column;
          gap: 1rem;
        }
      }
    </style>
  </body>
</html>
